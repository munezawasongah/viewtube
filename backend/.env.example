# ─── Server ─────────────────────────────────────────────
PORT=3001
# Comma-separated list of allowed frontend origins (leave empty to allow all — NOT recommended in production)
FRONTEND_URL=https://your-frontend.vercel.app
# Public URL of THIS API — required for the M-Pesa callback
API_URL=https://your-api.up.railway.app

# ─── Firebase (required) ────────────────────────────────
# Paste the full service-account JSON as ONE line
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Cloudflare Stream (required) ───────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
# Optional: set the same secret in the Cloudflare Stream webhook config
CF_WEBHOOK_SECRET=

# ─── M-Pesa Daraja (optional — payments disabled if unset)
# sandbox | production
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
# Sandbox shortcode is 174379. Use your real Paybill/Till for production.
MPESA_SHORTCODE=174379
MPESA_PASSKEY=

# ─── Admin (comma-separated emails that can view advertising enquiries)
ADMIN_EMAILS=eokoth2019@gmail.com
